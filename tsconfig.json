{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "lib": ["ESNext", "DOM"],
    "typeRoots": ["./node_modules/@types", "./dist"]
  },
  "include": ["src", "test"],
  "exclude": ["node_modules", "dist"]
}
